GEMINI_API_KEY=your_gemini_key_here
GROQ_API_KEY=your_groq_key_here
OPENROUTER_API_KEY=

# Reddit API (for live trends — optional, mock data used without these)
# Create an app at: https://www.reddit.com/prefs/apps
REDDIT_CLIENT_ID=your_reddit_client_id
REDDIT_CLIENT_SECRET=your_reddit_client_secret
REDDIT_USER_AGENT=ViralOS/1.0
REDDIT_SUBREDDITS=technology,artificial,MachineLearning,worldnews,todayilearned

# YouTube API (for live uploads — optional, saves JSON without these)
# Enable YouTube Data API v3 at: https://console.cloud.google.com
YOUTUBE_API_KEY=
ELEVENLABS_API_KEY=

# Notifications
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
